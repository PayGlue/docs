{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PayGlue Docs",
  "colors": {
    "primary": "#4F46E5",
    "light": "#6366F1",
    "dark": "#4338CA"
  },
  "favicon": {
    "light": "/images/payglue-icon.svg",
    "dark": "/images/payglue-icon.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Payglue.io",
          "icon": "home",
          "href": "https://payglue.io"
        },
        {
          "anchor": "Dashboard",
          "href": "https://app.payglue.io/login",
          "icon": "analytics"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/payglue-logo-dark.svg",
    "dark": "/images/payglue-logo-light.svg",
    "href": "https://payglue.io"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:team@payglue.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "background": {
    "color": {
      "dark": "#0F172A"
    }
  },
  "description": "Connect Ghost memberships to any payment provider. Step-by-step guides, setup, and troubleshooting."
}
